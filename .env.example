# ===========================================
# MediChat 环境变量配置
# 使用小米 MIMO 模型
# ===========================================

# 数据库配置
POSTGRES_PASSWORD=medichat123
DATABASE_URL=postgresql://medichat:medichat123@localhost:5432/medichat

# Redis配置
REDIS_URL=redis://localhost:6379/0

# Milvus向量数据库
MILVUS_HOST=localhost
MILVUS_PORT=19530

# 小米 MIMO 模型配置
MIMO_API_KEY=your_mimo_api_key_here
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2-pro

# 备用模型（可切换）
# MIMO_MODEL=mimo-v2-flash  # 更快、更便宜

# 搜索工具
SERPER_API_KEY=your_serper_api_key_here

# 应用配置
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=your_secret_key_here

# Second Me 集成
# LOCAL_MODE=true: 使用MediChat内置的本地模拟分身
# LOCAL_MODE=false: 对接真实 Second Me 后端（默认 Docker 后端是 8002）
LOCAL_MODE=true
SECONDME_API=http://localhost:8002
SECONDME_ENABLE_L0_RETRIEVAL=false

# SecondMe OAuth 平台接入
SECONDME_CLIENT_ID=your_secondme_client_id
SECONDME_CLIENT_SECRET=your_secondme_client_secret
SECONDME_REDIRECT_URI=http://localhost:8001/api/v1/secondme/oauth/callback
SECONDME_POST_LOGIN_REDIRECT=http://localhost:8001/index.html
SECONDME_OAUTH_SCOPES=userinfo,note.write
# 推荐显式带上 scope，便于联调时核对 code exchange 与授权范围
SECONDME_OAUTH_INCLUDE_SCOPE_IN_REDIRECT=true
SECONDME_AUTHORIZE_URL=https://go.second.me/oauth/
SECONDME_API_BASE=https://api.mindverse.com/gate/lab
# 本地调试时把 token 保存在服务端受控 secret 文件，不暴露给前端
SECONDME_SECRET_STORE_PATH=.secrets/secondme_oauth.json
SECONDME_SESSION_COOKIE_NAME=medichatrd_secondme_sid
SECONDME_SESSION_COOKIE_MAX_AGE=2592000
SECONDME_SESSION_COOKIE_SECURE=false

# 运行时后台切换口令（只用于平台治理页切换 Local/SecondMe provider）
PLATFORM_ADMIN_TOKEN=

# 医疗合规
ENABLE_MEDICAL_DISCLAIMER=true
LOG_RETENTION_DAYS=90
