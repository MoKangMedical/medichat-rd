# MediChat-RD 环境配置

# 模式切换
# true = 模拟模式（无需Second Me服务）
# false = 连接真正的Second Me服务
LOCAL_MODE=true

# Second Me API地址（LOCAL_MODE=false时生效）
SECONDEME_API=http://localhost:3000

# MIMO API（用于AI推理）
# 如未配置，将使用模拟模式
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2-pro
MIMO_MEDIA_MODEL=mimo-v2-omni
MIMO_TTS_MODEL=mimo-v2-tts
MIMO_TTS_VOICE=default_zh
MIMO_TTS_FORMAT=wav

# 服务端口
PORT=8001
