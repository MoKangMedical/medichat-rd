# MediChat-RD production environment for Tencent Cloud Lighthouse
# Copy to /opt/medichat-rd/.env.local on the server.

APP_ENV=production
APP_DEBUG=false
SECRET_KEY=replace_with_a_long_random_secret

# Current production recommendation:
# - Keep LOCAL_MODE=true for initial public launch
# - Turn this off only after a stable hosted Second-Me backend exists
LOCAL_MODE=true
SECONDME_ENABLE_L0_RETRIEVAL=false

# SecondMe OAuth
SECONDME_CLIENT_ID=replace_with_secondme_client_id
SECONDME_CLIENT_SECRET=replace_with_secondme_client_secret
SECONDME_REDIRECT_URI=https://medichatrd.cloud/api/v1/secondme/oauth/callback
SECONDME_POST_LOGIN_REDIRECT=https://medichatrd.cloud/
SECONDME_OAUTH_SCOPES=userinfo,note.write
SECONDME_OAUTH_INCLUDE_SCOPE_IN_REDIRECT=true
SECONDME_AUTHORIZE_URL=https://go.second.me/oauth/
SECONDME_API_BASE=https://api.mindverse.com/gate/lab
SECONDME_SECRET_STORE_PATH=/opt/medichat-rd/.secrets/secondme_oauth.json
SECONDME_SESSION_COOKIE_NAME=medichatrd_secondme_sid
SECONDME_SESSION_COOKIE_MAX_AGE=2592000
SECONDME_SESSION_COOKIE_SECURE=true

# Runtime control plane
PLATFORM_ADMIN_TOKEN=replace_with_runtime_admin_token

# Optional upstreams
MIMO_API_KEY=replace_if_used
SERPER_API_KEY=replace_if_used

# If later migrating to persistent external infra, replace these too.
DATABASE_URL=
REDIS_URL=
MILVUS_HOST=
MILVUS_PORT=
